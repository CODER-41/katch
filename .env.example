# ============================================
# KAKAMEGA SCHOOL - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================
# FLASK APPLICATION
# ============================================

# Flask Secret Key - Used for session management and security
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# JWT Secret Key - Used for JWT token signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database_name
# 
# LOCAL DEVELOPMENT:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/kakamega_school
#
# PRODUCTION (Render/Heroku):
# Get from your database provider dashboard
# Render: Dashboard > Database > Internal Database URL
# Note: The app automatically converts "postgres://" to "postgresql://"
DATABASE_URL=postgresql://username:password@host:port/database_name

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================

# Gmail account for sending contact form notifications
# IMPORTANT: You must enable "App Passwords" in your Google Account
# 
# HOW TO GET APP PASSWORD:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification (if not already enabled)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Other (Custom name)"
# 5. Name it "Kakamega School App"
# 6. Copy the 16-character password (no spaces)
# 7. Use that password below (NOT your regular Gmail password)
#
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================

# Cloudinary for document/image uploads
# Sign up at: https://cloudinary.com/users/register/free
#
# HOW TO GET CLOUDINARY CREDENTIALS:
# 1. Go to https://cloudinary.com and sign up for a free account
# 2. After login, go to Dashboard
# 3. Copy your "Cloud Name" (e.g., da0mkvthw)
# 4. Go to Settings > Upload > Upload Presets
# 5. Click "Add upload preset"
# 6. Set Preset Name: admissions_docs
# 7. Set Signing Mode: "Unsigned"
# 8. Set Folder: admissions (optional but recommended)
# 9. Save the preset
# 10. Use the Cloud Name and Preset Name below
#
# NOTE: These are used in the frontend (src/pages/Admissions.tsx)
# Update CLOUD_NAME and UPLOAD_PRESET constants in that file
#
CLOUDINARY_CLOUD_NAME=da0mkvthw
CLOUDINARY_UPLOAD_PRESET=admissions_docs

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend URL for CORS configuration
# LOCAL: http://localhost:8080
# PRODUCTION: https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:8080

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# BACKEND (Render/Heroku):
# - Add all these variables in your dashboard's Environment Variables section
# - DATABASE_URL is usually auto-provided by the database service
# - Make sure to set SECRET_KEY and JWT_SECRET_KEY to strong random values
#
# FRONTEND (Vercel):
# - No environment variables needed for frontend
# - API URL is hardcoded in src/services/api.ts
# - Update API_URL in api.ts to match your backend deployment URL
#
# LOCAL DEVELOPMENT:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values in .env
# 3. Install PostgreSQL locally or use a cloud database
# 4. Run migrations: flask db upgrade (if using Flask-Migrate)
# 5. Start backend: python run.py
# 6. Start frontend: npm run dev
#
# ============================================
